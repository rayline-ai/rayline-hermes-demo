# rayline-hermes-demo — copy to `.env` and fill in.
# Loaded into the sandbox shell via ~/.bashrc (set -a). Never commit `.env`.

# --- Rayline ---------------------------------------------------------------
# Router key (starts with `rlk-`). Mint one at https://platform.rayline.ai/keys.
# Read by the rld router daemon inside the sandbox; authenticates to the Rayline cloud.
RAYLINE_ROUTER_API_KEY=

# --- Telegram --------------------------------------------------------------
# Bot token from @BotFather (/newbot). Setting this auto-enables the Telegram platform.
TELEGRAM_BOT_TOKEN=

# Access control. For a demo, open it to everyone:
GATEWAY_ALLOW_ALL_USERS=true
# ...or restrict to specific numeric Telegram user IDs (comma-separated) and unset the line above:
# TELEGRAM_ALLOWED_USERS=

# --- Anthropic placeholder -------------------------------------------------
# Hermes' `anthropic` provider sends this as x-api-key to the Rayline injector, which
# ignores it and injects the real credential (RAYLINE_ROUTER_API_KEY) upstream. Any value works.
ANTHROPIC_API_KEY=sk-ant-rayline-injector-placeholder
